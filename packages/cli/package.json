{
  "name": "kyokao",
  "version": "0.3.0",
  "description": "A safe, local-first coding agent",
  "type": "module",
  "bin": {
    "kyokao": "./dist/kyokao.cjs"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {},
  "scripts": {
    "build": "tsc -p tsconfig.build.json && esbuild dist/index.js --bundle --platform=node --format=cjs --outfile=dist/kyokao.cjs && chmod +x dist/kyokao.cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "tsx src/index.ts",
    "prepack": "node ../../scripts/package-assets.mjs"
  },
  "devDependencies": {
    "commander": "^12.1.0",
    "@kyokao/agent": "workspace:*",
    "@kyokao/config": "workspace:*",
    "@kyokao/memory": "workspace:*",
    "@kyokao/providers": "workspace:*",
    "@kyokao/tools": "workspace:*",
    "@kyokao/ui": "workspace:*"
  }
}
