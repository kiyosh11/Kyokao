{
  "name": "kyokao",
  "version": "0.8.0",
  "description": "A safe local and Capy remote coding agent",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kiyosh11/Kyokao.git"
  },
  "bugs": {
    "url": "https://github.com/kiyosh11/Kyokao/issues"
  },
  "homepage": "https://github.com/kiyosh11/Kyokao#readme",
  "type": "module",
  "bin": {
    "kyokao": "./dist/kyokao.cjs"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {},
  "scripts": {
    "build": "tsc -p tsconfig.build.json && esbuild dist/index.js --bundle --platform=node --format=cjs --outfile=dist/kyokao.cjs && node -e \"require('node:fs').chmodSync('dist/kyokao.cjs', 0o755)\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "tsx src/index.ts",
    "prepack": "node ../../scripts/package-assets.mjs"
  },
  "devDependencies": {
    "commander": "^12.1.0",
    "@kyokao/agent": "workspace:*",
    "@kyokao/config": "workspace:*",
    "@kyokao/memory": "workspace:*",
    "@kyokao/providers": "workspace:*",
    "@kyokao/tools": "workspace:*",
    "@kyokao/ui": "workspace:*",
    "@kyokao/themes": "workspace:*"
  }
}
