{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@kyokao/config": ["packages/config/src/index.ts"],
      "@kyokao/providers": ["packages/providers/src/index.ts"],
      "@kyokao/tools": ["packages/tools/src/index.ts"],
      "@kyokao/memory": ["packages/memory/src/index.ts"],
      "@kyokao/agent": ["packages/agent/src/index.ts"],
      "@kyokao/ui": ["packages/ui/src/index.ts"]
    }
  }
}
