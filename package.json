{
  "name": "kyokao-workspace",
  "private": true,
  "version": "0.5.3",
  "packageManager": "pnpm@10.31.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "vitest run",
    "test:pty": "node scripts/pty-integration.mjs",
    "kyokao": "pnpm --filter kyokao start"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "esbuild": "^0.24.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "description": "Kyokao is a TypeScript coding-agent CLI with local OpenAI-compatible and Capy remote backends.",
  "main": "index.js",
  "directories": {
    "test": "test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kiyosh11/Kyokao.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/kiyosh11/Kyokao/issues"
  },
  "homepage": "https://github.com/kiyosh11/Kyokao#readme"
}
